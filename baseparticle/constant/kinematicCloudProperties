cloudFunctions
{
    
    outletParticles
    {
        type              particlePostProcessing;
        log               true;
        maxStoredParcels  1e7;
        executeControl    timeStep;
        executeInterval   1;
        writeControl      writeTime;
        writeInterval     1;
        patches (outlet);
    }
    

    wallSubstrateParticles
