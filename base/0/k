FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 1e-100;

boundaryField
{
    inletAerosol
    {
        type            turbulentIntensityKineticEnergyInlet;
        intensity       0.01;
        value           $internalField;
    }

    inletSheath
    {
        type            turbulentIntensityKineticEnergyInlet;
        intensity       0.01;
        value           $internalField;
    }

    outlet
    {
        //type            inletOutlet;
        type            zeroGradient;
        //inletValue	    uniform 1e-5;
    	value		    $internalField;
    }

    "wall.*"
    {
    //        type            kLowReWallFunction;
        type kqRWallFunction; 
        //type            fixedValue;
        value           uniform 1e-100;
    }

    "(front|back)"
    {
        type            wedge;
    }
 
}


