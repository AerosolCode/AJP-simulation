FoamFile
{
    format      ascii;
    class       volScalarField;
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    inletSheath
    {
        type            zeroGradient;
        value           uniform 0;
    }
    inletAerosol
    {
        type            zeroGradient;
        value           uniform 0;
    }
    outlet
    {
        type            fixedValue;
        value           uniform 0;
    }
    "(wall.*)"
    {
        type            zeroGradient;
    }
    "(front|back)"
    {
        type            wedge;
    }

}

